{% extends "layout.twig" %}

{% block content %}
    <nav class="breadcrumb">
        <a href="/versions">Versions</a> &raquo; <span>{{ version.tag }}</span>
    </nav>

    <section class="hero hero-compact">
        <div>
            <p class="eyebrow">Version Details</p>
            <h1>{{ version.tag }}</h1>
        </div>
        <div class="hero-actions">
            <a href="/versions/{{ version.id }}/symbols" class="button button-primary">Browse Symbols</a>
        </div>
    </section>

    <div class="grid two-up">
        <section class="panel">
            <div class="panel-head">
                <h2>Compare & Analyze Impact</h2>
            </div>
            <p class="muted">Analyze how an upgrade to this version impacts the internal extension graph.</p>
            <form action="/versions/{{ version.id }}/compare" method="get" class="form">
                <label>
                    <span>Compare with base version</span>
                    <select name="with" required>
                        <option value="">-- Select base version --</option>
                        {% for av in available_versions %}
                            {% if av.id != version.id %}
                                <option value="{{ av.id }}">{{ av.tag }}</option>
                            {% endif %}
                        {% endfor %}
                    </select>
                </label>
                <button type="submit" class="button">Analyze Impact</button>
            </form>
        </section>

        <section class="panel">
            <div class="panel-head">
                <h2>Statistics</h2>
            </div>
            <div class="stat-grid">
                <div class="stat-item">
                    <span class="label">Major</span>
                    <span class="value">{{ version.major }}</span>
                </div>
                <div class="stat-item">
                    <span class="label">Minor</span>
                    <span class="value">{{ version.minor }}</span>
                </div>
                <div class="stat-item">
                    <span class="label">Patch</span>
                    <span class="value">{{ version.patch }}</span>
                </div>
                <div class="stat-item">
                    <span class="label">Files</span>
                    <span class="value">{{ version.file_count|number_format }}</span>
                </div>
                <div class="stat-item">
                    <span class="label">Symbols</span>
                    <span class="value">{{ version.symbol_count|number_format }}</span>
                </div>
                <div class="stat-item">
                    <span class="label">Indexed</span>
                    <span class="value">{{ version.indexed_at|date('Y-m-d H:i') }}</span>
                </div>
            </div>
        </section>

    </div>

    {% set language_labels = {
        'php': 'PHP', 'javascript': 'JavaScript', 'css': 'CSS',
        'yaml': 'YAML', 'twig': 'Twig', 'drupal_libraries': 'Libraries'
    } %}
    {% set type_labels = {
        'function': 'Functions', 'class': 'Classes', 'method': 'Methods',
        'constant': 'Constants', 'variable': 'Variables', 'hook': 'Hooks',
        'css_selector': 'Selectors', 'service': 'Services', 'route': 'Routes',
        'permission': 'Permissions', 'drupal_library': 'Libraries',
        'library_usage': 'Library Usages', 'interface': 'Interfaces',
        'trait': 'Traits', 'enum': 'Enums', 'template': 'Templates',
        'config_schema': 'Config Schemas', 'content_type': 'Content Types',
        'field': 'Fields', 'plugin': 'Plugins', 'event': 'Events'
    } %}

    <section>
        <div class="panel-head">
            <h2>Symbol Distribution</h2>
        </div>
        <div class="grid three-up">
            {% for lang, types in stats_by_language %}
                <a href="/versions/{{ version.id }}/symbols?language={{ lang }}" class="lang-card lang-card--{{ lang }}">
                    <div class="lang-card__head">
                        <span class="badge badge-lang badge-lang--{{ lang }}">{{ language_labels[lang] ?? lang }}</span>
                        <span class="lang-card__total">{{ language_totals[lang]|number_format }}</span>
                    </div>
                    <ul class="lang-card__types">
                        {% for row in types %}
                            <li>
                                <span>{{ type_labels[row.symbol_type] ?? row.symbol_type }}</span>
                                <span class="muted">{{ row.cnt|number_format }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                </a>
            {% endfor %}
        </div>
    </section>
{% endblock %}
