{
    "name": "andypost/drupalevolver",
    "description": "PHP CLI tool that uses tree-sitter to analyze Drupal core changes and assist with upgrades",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "minimum-stability": "stable",
    "require": {
        "php": "^8.5",
        "ext-ffi": "*",
        "ext-igbinary": "*",
        "ext-pdo_sqlite": "*",
        "symfony/console": "^8.0"
    },
    "require-dev": {
        "amphp/parallel": "^2.3",
        "phpunit/phpunit": "^11.0",
        "mikey179/vfsstream": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "DrupalEvolver\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DrupalEvolver\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/evolver"]
}
